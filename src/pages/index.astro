---
import Layout from '../layouts/Layout.astro'

import { profile } from '@/settings'
import { experiences, education } from '@/types/cv'
import Hero from '@/components/ui/Hero.astro'
import Grid from '@/components/ui/Grid.astro'
import ArticleList from '@/components/ui/ArticleList.astro'
import CvTimeline from '@/components/ui/CvTimeline.astro'
import School from '@/components/icons/School.astro';
import WorldMap from '@/components/icons/WorldMap.astro';

import Python from '@/components/icons/python.astro';
import Java from '@/components/icons/java.astro';
import CSharp from '@/components/icons/csharp.astro';
import Net from '@/components/icons/net.astro';
import SQL from '@/components/icons/sql.astro';
import Html from '@/components/icons/html.astro';
import Css from '@/components/icons/css.astro';

import JavaScript from '@/components/icons/js.astro';
import Flask from '@/components/icons/flask.astro';
import React from '@/components/icons/react.astro';
import MongoDB from '@/components/icons/mongodb.astro';

import GitHub from '@/components/icons/git.astro';


const { fullName, title, institute, research_areas } = profile
---


<Layout>
    <!-- Hero Section -->
    <section id="home" class="h-screen flex flex-col justify-center items-start text-left">
      <Hero
        fullName={fullName}
      />
    </section>

    <!-- CV Section -->
<section id="cv" class="px-4 sm:px-0 py-24 text-gray-900">
  <div class="bg-white/30 rounded-xl shadow-md overflow-hidden p-4 sm:p-8 max-w-7xl mx-auto">
    <div>
      {/* ref: CV Section */}
      <!-- Education -->
      <div>
        <h2 class="text-4xl font-bold mb-8 text-left">Nusaibah Binte Rawnak</h2>
        <div class="mb-6">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-2 gap-1">
            <a href="https://coursecatalogue.mcgill.ca/en/undergraduate/arts-science/programs/cognitive-science/cognitive-science-interfaculty-program-basc/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110">
                <span>{education[0].degree}</span><span class="hover-arrow">→</span>
            </a>
            <div class="text-sm italic text-gray-700 text-right">{education[0].time}</div>
          </div>
          <div class="text-sm text-gray-700">
            {education[0].conc}
          </div>
          <p class="text-sm text-gray-700">&nbsp;</p>
          <div class="text-base text-gray-700 flex items-center gap-2">
            <School class="w-4 h-4" />
            <a href="https://www.mcgill.ca" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110">
              <span>{education[0].school}</span><span class="hover-arrow">→</span>
            </a>
          </div>
          <div class="text-base text-gray-700 flex items-center gap-2">
            <WorldMap class="w-4 h-4" /> {education[0].location}
          </div>
          <div class="mt-6">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Notable Courses Completed</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-5">

              <!-- MATH -->
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide mb-2 block" style="color: rgb(254, 15, 205);">Mathematics</span>
                <ul class="list-disc list-inside text-gray-700 text-sm space-y-1">
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-208/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 208 Introduction to Statistical Computing</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-222/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 222 Calculus 3</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-223/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 223 Linear Algebra</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-240/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 240 Discrete Structures</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-323/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 323 Probability</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-324/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 324 Statistics</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/math-423/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>MATH 423 Applied Regression</span><span class="hover-arrow">→</span></a></li>
                </ul>
              </div>

              <!-- COMP -->
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide mb-2 block" style="color: rgb(254, 15, 205);">Computer Science</span>
                <ul class="list-disc list-inside text-gray-700 text-sm space-y-1">
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-206/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 206 Introduction to Software Systems</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-251/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 251 Algorithms and Data Structures</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-345/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 345 Natural Language to Data Science</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-445/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 445 Computational Linguistics</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-545/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 545 Computational Semantics with Neural Networks</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-550/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 550 Natural Language Processing</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-551/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 551 Applied Machine Learning</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/comp-579/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>COMP 579 Reinforcement Learning</span><span class="hover-arrow">→</span></a></li>
                </ul>
              </div>

              <!-- PSYC -->
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide mb-2 block" style="color: rgb(254, 15, 205);">Psychology</span>
                <ul class="list-disc list-inside text-gray-700 text-sm space-y-1">
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/psyc-204/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>PSYC 204 Introduction to Psychological Statistics</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/psyc-211/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>PSYC 211 Introductory Behavioural Neuroscience</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/psyc-213/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>PSYC 213 Cognition</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/nsci-201/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>NSCI 201 Introduction to Neuroscience 2</span><span class="hover-arrow">→</span></a></li>
                </ul>
              </div>

              <!-- LING -->
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide mb-2 block" style="color: rgb(254, 15, 205);">Linguistics</span>
                <ul class="list-disc list-inside text-gray-700 text-sm space-y-1">
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/ling-201/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>LING 201 Introduction to Linguistics</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/ling-345/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>LING 345 From Natural Language to Data Science</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/ling-371/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>LING 371 Syntax 1</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/ling-445/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>LING 445 Computational Linguistics</span><span class="hover-arrow">→</span></a></li>
                  <li><a href="https://coursecatalogue.mcgill.ca/courses/ling-545/" target="_blank" rel="noopener noreferrer" class="transition-transform duration-300 hover:text-purple-700 hover:font-bold transform hover:scale-110"><span>LING 545 Computational Semantics with Neural Networks</span><span class="hover-arrow">→</span></a></li>
                </ul>
              </div>

            </div>
          </div>
          </div>
        </div>
      </div>

      <!-- Experience -->
      <div>
        <h2 class="text-4xl font-bold mb-8 text-left">Experience</h2>

        {[...experiences].map((exp) => (
          <div class="mb-8">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <div class="text-lg font-bold mt-1">
                {exp.title}
                <span class="font-normal"> @ {exp.company}</span>
              </div>
              <div class="text-sm italic text-gray-700 sm:text-right">{exp.time}</div>
            </div>
            <div class="text-sm text-gray-700">{exp.location}</div>
            {exp.bullets && exp.bullets.length > 0 && (
              <ul class="list-disc list-inside mt-2 space-y-1 text-gray-800">
                {exp.bullets.map(point => (
                  <li>{point}</li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

   <!-- Projects Section -->
<section id="projects" class="py-24 text-gray-900">
<h2 class="text-4xl font-bold mb-12 text-center">Projects</h2>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 px-4 sm:px-8 max-w-7xl mx-auto">

  <!-- Project 1: LLM Time Series Forecasting -->
  <div class="bg-white/60 rounded-xl shadow-md overflow-hidden p-6 flex flex-col justify-between">
    <img src="/llm-demo.gif" alt="LLM Forecasting demo" class="rounded-lg mb-4 w-full max-h-56 object-cover" />
    <div>
        <h3 class="text-xl font-bold mb-2">Context Helps, But Only at Scale: Evaluating Practical LLMs for Time Series Forecasting</h3>
        <p class="mb-4 text-sm text-gray-700">
          Benchmarked LLM architectures (Llama 3.2, GPT-4o-mini, Mixtral) against classical methods (ARIMA, ETS) across 120 forecasting tasks spanning 12 domains including finance, energy, and transportation. Developed XGBoost routing classifier achieving 89.5% of optimal performance while reducing LLM usage by 69%, enabling practical deployment for resource-constrained environments.
        </p>
      </div>
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Python</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">LLMs</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">XGBoost</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Time Series</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Machine Learning</span>
        </div>
        <a href="/context-helps-but-only-at-a-scale.pdf" target="_blank" rel="noopener noreferrer" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
          Read Paper →
        </a>
        <a href="https://llmbenchmark-frontend.vercel.app" target="_blank" rel="noopener noreferrer" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300 ml-2">
          Live Demo →
        </a>
      </div>
    </div>

  <!-- Project 2: Customer Support AI -->
    <div class="bg-white/60 rounded-xl shadow-md overflow-hidden p-6 flex flex-col justify-between">
      <img src="/customer-support-ai.gif" alt="Customer Support AI demo" class="rounded-lg mb-4 w-full max-h-56 object-cover" />
      <div>
        <h3 class="text-xl font-bold mb-2">Customer Support AI: Multi-Agent System</h3>
        <p class="mb-4 text-sm text-gray-700">
          Built a multi-agent AI system for customer support executives to query structured customer data and unstructured policy documents using natural language. A LangGraph supervisor routes queries to a SQL agent (SQLite) or RAG agent (ChromaDB) — each backed by a FastMCP server — with responses synthesized by Google Gemini 2.5 Flash Lite. Features a Streamlit UI with PDF upload and per-response route indicators.
        </p>
      </div>
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Python</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">LangGraph</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">LangChain</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">FastMCP</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">RAG</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">ChromaDB</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Gemini</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Streamlit</span>
        </div>
        <div class="flex gap-3 flex-wrap">
          <a href="https://www.loom.com/share/4ce1aa3ef8f949e88155efbd44ba8e11" target="_blank" rel="noopener noreferrer" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            View Demo →
          </a>
          <a href="https://github.com/Nusaibah-Rawnak/customer-support-ai" target="_blank" rel="noopener noreferrer" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            View on GitHub →
          </a>
        </div>
      </div>
    </div>

  <!-- Project 3: Linear Text Classification -->
    <div class="bg-white/60 rounded-xl shadow-md overflow-hidden p-6 flex flex-col justify-between">
      <div>
        <img src="/nlp-demo.gif" alt="NLP Classifier Playground demo" class="rounded-lg mb-4 w-full max-h-56 object-cover" />
        <h3 class="text-xl font-bold mb-2">Linear Text Classification: Semantics vs. Spelling</h3>
        <p class="mb-4 text-sm text-gray-700">
          Implemented and compared logistic regression and linear SVM classifiers to distinguish semantic (sentiment) vs. morphophonological (alliteration) features in text. Explored preprocessing techniques including lowercase normalization, stopword removal, TF-IDF weighting, and n-gram feature extraction. Achieved 93.75% accuracy on alliteration detection and 70.83% on sentiment classification, demonstrating a 23-percentage-point gap that reveals linear classifiers excel at explicit spelling patterns over semantic understanding.
        </p>
      </div>
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Python</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Scikit-learn</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">NLP</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Machine Learning</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Text Classification</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">FastAPI</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">React</span>
        </div>
        <div class="flex gap-3 flex-wrap">
          <a href="https://nlp-classifier-frontend.vercel.app" target="_blank" rel="noopener noreferrer" class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            Live Demo →
          </a>
          <a href="https://github.com/Nusaibah-Rawnak/linear-text-classification" target="_blank" rel="noopener noreferrer" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            View on GitHub →
          </a>
          <a href="https://github.com/Nusaibah-Rawnak/linear-text-classification/blob/main/report.pdf" target="_blank" rel="noopener noreferrer" class="inline-block border-2 border-purple-700 text-purple-700 hover:bg-purple-700 hover:text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            Read Report →
          </a>
        </div>
      </div>
    </div>

    <!-- Project 4: Fashion-MNIST Neural Networks -->
    <div class="bg-white/60 rounded-xl shadow-md overflow-hidden p-6 flex flex-col justify-between">
      <div>
        <h3 class="text-xl font-bold mb-2">Neural Network Architectures for Fashion-MNIST</h3>
        <p class="mb-4 text-sm text-gray-700">
          Systematic evaluation of neural network architectures for image classification, comparing MLPs implemented from scratch in NumPy with PyTorch CNNs and transfer learning. Explored depth, activation functions, regularization, and data augmentation effects. Achieved 92.40% accuracy with a CNN using dropout regularization, demonstrating a 7.20% improvement over the best MLP and revealing that convolutional feature extraction significantly outperforms fully-connected architectures for spatial data.
        </p>
      </div>
      <div>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Python</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">PyTorch</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">NumPy</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Deep Learning</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">CNN</span>
          <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Transfer Learning</span>
        </div>
        <div class="flex gap-3">
          <a href="https://github.com/Nusaibah-Rawnak/fashion-mnist-neural-networks" target="_blank" rel="noopener noreferrer" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            View on GitHub →
          </a>
          <a href="https://github.com/Nusaibah-Rawnak/fashion-mnist-neural-networks/blob/main/writeup.pdf" target="_blank" rel="noopener noreferrer" class="inline-block border-2 border-purple-700 text-purple-700 hover:bg-purple-700 hover:text-white font-semibold px-4 py-2 rounded transition-colors duration-300">
            Read Report →
          </a>
        </div>
      </div>
    </div>


  <!-- Project 5: Track Split -->
    <div class="bg-white/60 rounded-xl shadow-md overflow-hidden p-6 flex flex-col justify-between">
      <img src="/tsplit.png" alt="Track Split App" class="rounded mb-4 w-full max-h-64 object-cover" />
      <div>
        <h3 class="text-xl font-bold mb-2">Track Split: AI-Powered Expense Tracker</h3>
        <p class="mb-4 text-sm text-gray-700">
          Currently developing an expense platform with dynamic visualizations and ML-driven spending insights. Integrating OCR-based bill scanning and intelligent group-splitting to streamline expense management. Built with a Next.js frontend, serverless API routes, and PostgreSQL via Prisma, deployed on Vercel.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 mt-auto">
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">TypeScript</span>
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Python</span>
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Next.js</span>
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">PostgreSQL</span>
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">Prisma</span>
        <span class="bg-indigo-600 text-white px-3 py-1 rounded-full text-sm">OCR</span>
      </div>
    </div>

  </div>
</section>

    <!-- Footer -->
    <footer class="text-center text-sm text-purple-700 py-6 mt-4">
      <p>Copyright © {new Date().getFullYear()} - All rights reserved by Nusaibah Binte Rawnak</p>
    </footer>

</Layout>

<style>
  .hover-arrow {
    display: inline-block;
    transition: transform 0.3s ease, opacity 0.3s ease;
    margin-left: 0.2em;
    opacity: 0;
    transform: translate(-4px, -4px);
  }

  a:hover .hover-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>
